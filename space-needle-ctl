#!/usr/bin/env bash
# space-needle-ctl — manage space-needle services
set -euo pipefail

CONTROL_PLANE_DIR="$(cd "$(dirname "$0")/control-plane" && pwd)"

usage() {
  echo "Usage: $0 <command> [<service>]"
  echo ""
  echo "Commands:"
  echo "  --deploy <service|--all>  Pull images and restart (with health checks)"
  echo "  --start  <service|--all>  Start containers"
  echo "  --stop   <service|--all>  Stop containers"
  echo "  --health [service]        Run health checks (all services, or one)"
  echo "  --update                  Pull latest config from git"
  echo ""
  echo "Services: plex media pupyrus iditarod"
  exit 0
}

if [[ $# -eq 0 ]]; then
  usage
fi

case "$1" in
  --deploy) bash "$CONTROL_PLANE_DIR/deploy.sh" "${2:-}" ;;
  --start)  bash "$CONTROL_PLANE_DIR/start.sh"  "${2:-}" ;;
  --stop)   bash "$CONTROL_PLANE_DIR/stop.sh"   "${2:-}" ;;
  --health) bash "$CONTROL_PLANE_DIR/health.sh"  "${2:-}" ;;
  --update) bash "$CONTROL_PLANE_DIR/update.sh" ;;
  -h|--help) usage ;;
  *)
    echo "Unknown command: $1"
    usage
    ;;
esac
