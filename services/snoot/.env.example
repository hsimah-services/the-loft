# Snoot — Beszel agent (sniffs each host and reports to the houstn/beszel hub).
#
# Beszel SSH public key — generated by the hub after initial setup.
# In the Beszel web UI (https://beszel.loft.hsimah.com): Add System → copy the
# value after KEY= in the docker run command shown.
# This key is the same on all hosts — it belongs to the hub, not each agent.
BESZEL_KEY=
BESZEL_TOKEN=
