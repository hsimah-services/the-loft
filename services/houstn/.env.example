# Houstn — combined dashboards/monitoring stack
#
# beszel (Beszel hub) and uptime (Uptime Kuma) have no required environment variables —
# their admin accounts and configuration are set via the web UI on first access.
#   beszel  → https://beszel.loft.hsimah.com  (or http://beszel.space-needle)
#   uptime  → https://uptime.loft.hsimah.com  (or http://uptime.space-needle)
#
# homepage (Homepage dashboard) reads HOMEPAGE_VAR_* values from this file at startup
# and substitutes them into homepage-config/*.yaml. Access at:
#   homepage → https://homepage.loft.hsimah.com (or http://homepage.space-needle)

# ── Plex ─────────────────────────────────────────────────────────────────────
# Get your token from: Plex Settings → Account → X-Plex-Token (in a signed-in URL)
HOMEPAGE_VAR_PLEX_TOKEN=

# ── Stellarr *arr API keys ─────────────────────────────────────────────────────
# Found in each app under Settings → General → Security
HOMEPAGE_VAR_RADARR_API_KEY=
HOMEPAGE_VAR_SONARR_API_KEY=
HOMEPAGE_VAR_LIDARR_API_KEY=
HOMEPAGE_VAR_BAZARR_API_KEY=

# ── Transmission ──────────────────────────────────────────────────────────────
# Leave blank if you have not set credentials in Transmission
HOMEPAGE_VAR_TRANSMISSION_USERNAME=
HOMEPAGE_VAR_TRANSMISSION_PASSWORD=

# ── Soulseek (slskd) ──────────────────────────────────────────────────────────
# Generate an API key in slskd → Settings → Security → API Keys
HOMEPAGE_VAR_SLSKD_API_KEY=

# ── Uptime Kuma ───────────────────────────────────────────────────────────────
# Create a public Status Page in Uptime Kuma and set its slug here
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=
