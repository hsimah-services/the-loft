# GoToSocial host — use LAN IP or hostname (e.g. 192.168.1.100:8080)
GTS_HOST=localhost:8080

# Protocol — use http for LAN-only, https if you add a reverse proxy later
GTS_PROTOCOL=http

# How many days to cache remote media (federation only)
GTS_MEDIA_REMOTE_CACHE_DAYS=7

# Timezone
TZ=America/Los_Angeles
