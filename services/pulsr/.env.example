# GoToSocial host — the domain users see (routed via mushr reverse proxy)
GTS_HOST=pulsr.space-needle

# Protocol — https via Caddy internal TLS (self-signed)
GTS_PROTOCOL=https

# How many days to cache remote media (federation only)
GTS_MEDIA_REMOTE_CACHE_DAYS=7

# Timezone
TZ=America/Los_Angeles
