{
	admin 127.0.0.1:8880
	servers {
		protocols h1 h2
		trusted_proxies static private_ranges
	}
}

# ─── TLS snippet for Cloudflare DNS-01 challenge ─────────────────────────────
(cloudflare_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
}

# ══════════════════════════════════════════════════════════════════════════════
# HTTPS routes — *.loft.hsimah.com (Let's Encrypt via Cloudflare DNS-01)
# ══════════════════════════════════════════════════════════════════════════════

radarr.{$LOFT_DOMAIN} {
	import cloudflare_tls
	reverse_proxy radarr:7878
}

