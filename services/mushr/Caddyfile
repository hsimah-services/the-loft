{
	admin 127.0.0.1:8880
	servers {
		protocols h1 h2
		trusted_proxies static private_ranges
	}
}

# ─── TLS snippet for Cloudflare DNS-01 challenge ─────────────────────────────
(cloudflare_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
}

# ─── Pulsr snippet (shared between HTTPS and LAN routes) ─────────────────────
(pulsr_routes) {
	@gts path /api/* /.well-known/* /nodeinfo/* /oauth/* /users/* /@* /fileserver/* /settings /settings/* /auth/* /media/*
	handle @gts {
		reverse_proxy pulsr:8080 {
			header_up X-Real-IP {remote_host}
		}
	}
	handle {
		reverse_proxy pulsr-phanpy:80 {
			@notfound status 404
			handle_response @notfound {
				reverse_proxy pulsr:8080 {
					header_up X-Real-IP {remote_host}
				}
			}
		}
	}
}

