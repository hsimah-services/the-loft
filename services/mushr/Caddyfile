	import cloudflare_tls
	reverse_proxy pawst:80
}

http://hsimah.com {
	redir https://hsimah.com{uri} permanent
}

{$LOFT_DOMAIN} {
	import cloudflare_tls
	reverse_proxy pupyrus:80
}

