# Domain for HTTPS-enabled services (e.g. loft.hsimah.com)
# Services will be accessible at <service>.loft.hsimah.com with real TLS certs.
LOFT_DOMAIN=loft.hsimah.com

# Cloudflare API token for DNS-01 ACME challenge (Let's Encrypt cert issuance).
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > Zone > Read, Zone > DNS > Edit
# Scope: Include all zones (or the specific zone for your domain)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Cloudflare Tunnel token for external access to Pulsr.
# Create at: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
# Name: loft-pulsr, connector: Cloudflared
# Public hostname: pulsr.hsimah.com → HTTPS → mushr:443
#   Origin Server Name: pulsr.hsimah.com
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# hbla.ke: Add the hbla.ke domain to Cloudflare and ensure the API token
# above covers that zone. Then add a Cloudflare Tunnel public hostname:
#   hostname: hbla.ke → HTTPS → mushr:443
#   Origin Server Name: hbla.ke

# hsimah.com: Add the hsimah.com domain to Cloudflare and ensure the API
# token above covers that zone. Then add a Cloudflare Tunnel public hostname:
#   hostname: hsimah.com → HTTPS → mushr:443
#   Origin Server Name: hsimah.com

# Music Assistant API token for Spinnik vinyl controller.
# Generate in MA web UI: Settings > Security > API Tokens
MA_API_TOKEN=your-music-assistant-api-token-here

# Calavera's LAN IP for Icecast stream proxy (Spinnik visualizer).
# Find it with: ip addr show on calavera, or check router DHCP leases.
ICECAST_HOST=192.168.1.x

# Before deploying, also edit dnsmasq.conf and replace the listen-address
# and address entries with space-needle's actual LAN IP.
# Find it with: ip addr show | grep 'inet 192'
