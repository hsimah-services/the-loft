# Icecast passwords — ICECAST_SOURCE_PASSWORD must match the password in darkice.cfg
ICECAST_SOURCE_PASSWORD=lofty-vinyl-stream
ICECAST_ADMIN_PASSWORD=lofty-vinyl-stream

# Music Assistant host (hostname or IP of the server running MA)
MA_HOST=space-needle

# Music Assistant API token for Spinnik vinyl controller.
# Generate in MA web UI: Settings > Security > API Tokens
MA_API_TOKEN=your-music-assistant-api-token-here
