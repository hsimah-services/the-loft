COMPOSE_PROFILES=client                            # "server" or "client"

# Server-only: AirPlay names are set in shairport-sync config files
LIBRESPOT_NAME=The Loft Spotify                    # Spotify Connect device name (all speakers)
LIBRESPOT_NAME_VIKING=The Loft Spotify - Viking    # Spotify Connect device name (viking only)
LIBRESPOT_NAME_FJORD=The Loft Spotify - Fjord      # Spotify Connect device name (fjord only)
GMRENDER_NAME=The Loft DLNA                        # DLNA device name (all speakers)
GMRENDER_NAME_VIKING=The Loft DLNA - Viking        # DLNA device name (viking only)
GMRENDER_NAME_FJORD=The Loft DLNA - Fjord          # DLNA device name (fjord only)

# Client-only
SNAPSERVER_HOST=192.168.86.X                       # Snapserver IP address
SOUND_DEVICE=default                               # ALSA device
HOST_ID=change-me                                  # Room name for group persistence
